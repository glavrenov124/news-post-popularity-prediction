FROM python:3.12-slim

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV POETRY_VIRTUALENVS_CREATE=false

RUN pip install --no-cache-dir poetry

COPY pyproject.toml poetry.lock ./
RUN poetry install --only main,frontend --no-interaction --no-ansi --no-root

COPY . .

EXPOSE 8501

CMD ["streamlit", "run", "src/frontend/streamlit_app.py", "--server.address=0.0.0.0", "--server.port=8501"]